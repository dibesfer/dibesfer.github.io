function randomint(min, max) {
  return Math.floor(Math.random() * (max - min + 1) ) + min;
}

function shuffle(min, max) {

  var result;
  
  result = Math.floor(Math.random() * (max - min + 1) ) + min;

  while (latest_result == result) {
  		  result = Math.floor(Math.random() * (max - min + 1) ) + min;
  }

  latest_result = result;
  
  return result;
}

