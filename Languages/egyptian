<body>
The content of the body element is displayed in your browser.

<div id="showbox"></div>

</body>

<script>

	var glyphs = ["𓀞", "𓀟", "𓀠",
    "𓅰", "𓅯", "𓅮" ]
	var showbox = getid("showbox")
	var index = 0;

	function change_glyph(){
    
    	if (index < glyphs.length - 1){
    
    		index++;
        
        }
    
    	else {
        
        	index=0;
        
        }
        
        showbox.innerHTML = glyphs[index];
    
    }

    setInterval("change_glyph()",200);


</script>

